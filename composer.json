{
  "name": "wavevision/props-control",
  "description": "Create smart UI components for Nette Framework.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Wavevision s.r.o.",
      "email": "info@wavevision.com"
    },
    {
      "name": "Jakub Filla",
      "email": "jakub.filla@wavevision.com"
    },
    {
      "name": "Vít Rozsíval",
      "email": "vit@waveivison.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Wavevision\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Wavevision\\": "tests"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/SimplikoCZ/wavevision-utils.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/SimplikoCZ/wavevision-coding-standard.git"
    }
  ],
  "require": {
    "php": "~8.5.0",
    "ext-json": "*",
    "nette/application": "^3.2",
    "nette/schema": "^1.3",
    "wavevision/utils": "^3.0"
  },
  "require-dev": {
    "latte/latte": "^3.0",
    "nette/bootstrap": "^3.2",
    "php-coveralls/php-coveralls": "^2.5",
    "phpunit/phpunit": "^13.0",
    "symfony/css-selector": "^8.0",
    "symfony/dom-crawler": "^8.0",
    "wavevision/coding-standard": "^7.0"
  },
  "extra": {
    "phpstan": {}
  }
}
